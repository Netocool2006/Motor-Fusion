# NotebookLM Configuration
# Copia este archivo a .env y completa con tus valores

# ID del notebook de NotebookLM (aparece en la URL)
# Ejemplo: https://notebooklm.google.com/notebook/abc123xyz
NOTEBOOKLM_NOTEBOOK_ID=your-notebook-id-here

# (Opcional) Google Cloud Project ID
GOOGLE_PROJECT_ID=your-project-id

# (Opcional) Ruta a credentials.json
GOOGLE_CREDENTIALS_FILE=.credentials/credentials.json
