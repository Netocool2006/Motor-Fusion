    "2c3f568db85d": {
      "id": "2c3f568db85d",
      "type": "pattern",
      "key": "bom_to_propuesta",
      "solution": {
        "strategy": "bom_economic_transform",
        "notes": "BoM → Propuesta: NO es copy-paste. Pasos: 1) Analizar si precio BoM es competitivo o hay que ajustar. 2) Decidir MEP vs precio lista (consultar con AM). 3) Reestructurar pagos según necesidad cliente. 4) Aplicar IVA 12%. 5) Verificar que total propuesta sea coherente con BoM."
      },
      "tags": [
        "bom",
        "propuesta",
        "economica",
        "pricing"
      ],
