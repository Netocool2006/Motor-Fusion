  "entries": {
    "79ca047a3d18": {
      "id": "79ca047a3d18",
      "type": "pattern",
      "key": "validacion_checklist",
      "solution": {
        "strategy": "bom_validate_systematic",
        "notes": "Checklist validación BoM: 1) Matemática cuadre (subtotales, totales, IVA). 2) Part numbers existan y sean correctos. 3) Clasificación correcta (servicio/licencia/software/hardware/híbrido). 4) Tipo de cambio aplicado correctamente. 5) Periodicidad coherente (mensual, anual, one-time). 6) Cantidades lógicas. 7) Descuentos dentro de rango permitido."
      },
      "tags": [
        "bom",
        "validacion",
        "checklist",
        "math"
      ],
      "error_context": null,
