# ============================================================================
# Motor-Fusion Environment Configuration
# ============================================================================
# Copy this file to .env and customize for your environment
# All values have sensible defaults if not specified

# ---------------------------------------------------------------------------
# Data Directory Configuration
# ---------------------------------------------------------------------------
# Root directory for all Motor-Fusion data (knowledge, logs, state, etc.)
# Precedence: MOTOR_IA_DATA > HOME/.adaptive_cli > LOCALAPPDATA > Path.home()
# Default: Platform-dependent (see config.py for fallback chain)
MOTOR_IA_DATA=

# ---------------------------------------------------------------------------
# Ollama Configuration (Local LLM Provider)
# ---------------------------------------------------------------------------
# Base URL for Ollama API
OLLAMA_BASE_URL=http://localhost:11434

# Default model to use if not specified
OLLAMA_DEFAULT_MODEL=qwen3:4b

# HTTP timeout for Ollama requests (seconds)
OLLAMA_TIMEOUT_SECS=300

# RAM thresholds for context size selection
OLLAMA_RAM_HIGH_GB=4.0
OLLAMA_RAM_MID_GB=3.0

# Context sizes for different RAM profiles
OLLAMA_CTX_HIGH=4096
OLLAMA_CTX_MID=2048
OLLAMA_CTX_LOW=512

# ---------------------------------------------------------------------------
# Dashboard Server Configuration
# ---------------------------------------------------------------------------
# Port for Motor-Fusion dashboard web interface
DASHBOARD_PORT=7070

# Host to bind dashboard server
DASHBOARD_HOST=localhost

# ---------------------------------------------------------------------------
# MCP Server Configuration (Claude Integration)
# ---------------------------------------------------------------------------
# Port for MCP (Model Context Protocol) server
# Used for Claude CLI integration via stdio
MCP_SERVER_PORT=5000

# ---------------------------------------------------------------------------
# Claude CLI Integration
# ---------------------------------------------------------------------------
# Directory where Claude CLI stores settings and hooks
CLAUDE_CLI_HOME=

# Path to Claude CLI settings.json (auto-detected if not set)
CLAUDE_SETTINGS_PATH=

# ---------------------------------------------------------------------------
# Hooks Configuration
# ---------------------------------------------------------------------------
# Directory containing hook scripts
HOOKS_DIR=hooks

# Enable/disable hook execution (true/false)
HOOKS_ENABLED=true

# ---------------------------------------------------------------------------
# Knowledge Base Configuration
# ---------------------------------------------------------------------------
# Directory containing knowledge domains
KNOWLEDGE_BASE_DIR=knowledge

# Maximum KB context characters to inject (per query)
MAX_KB_CHARS=3000

# ---------------------------------------------------------------------------
# Session and Learning Configuration
# ---------------------------------------------------------------------------
# Confidence threshold for reusing learned patterns
CONFIDENCE_THRESHOLD=0.6

# Maximum pending errors to buffer
MAX_PENDING_ERRORS=15

# Domain detection: auto-assign threshold (keywords >= N)
AUTO_ASSIGN_THRESHOLD=2

# Domain detection: suggestion threshold (keywords >= N)
SUGGEST_THRESHOLD=1

# Minimum sessions required to auto-promote a domain
AUTO_DOMAIN_MIN_SESSIONS=3

# Minimum user messages in session to count as significant
AUTO_DOMAIN_MIN_MSGS=3

# ---------------------------------------------------------------------------
# Memory Management
# ---------------------------------------------------------------------------
# Enable automatic pattern pruning (true/false)
AUTO_PRUNE_ENABLED=true

# Success rate below which patterns are pruned
AUTO_PRUNE_MIN_SUCCESS_RATE=0.2

# Days without use before pattern is pruned
AUTO_PRUNE_DAYS_UNUSED=90

# Enable memory consolidation (true/false)
CONSOLIDATION_ENABLED=true

# Similarity threshold for consolidating patterns (Jaccard >= value)
CONSOLIDATION_SIMILARITY_THRESHOLD=0.7

# Maximum items in working memory per session
WORKING_MEMORY_MAX_ITEMS=50

# TTL for working memory items (hours)
WORKING_MEMORY_TTL_HOURS=24

# ---------------------------------------------------------------------------
# Logging and Debugging
# ---------------------------------------------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable debug output (true/false)
DEBUG_MODE=false

# ---------------------------------------------------------------------------
# Integration Timeouts (seconds)
# ---------------------------------------------------------------------------
# Deduplication window for duplicate detection
DEDUP_WINDOW_SECS=900

# Minimum gap between iterations
ITERATION_GAP_SECS=15

# Error correlation window
ERROR_CORRELATION_WINDOW=600

# Pattern confidence decay period (days)
CONFIDENCE_DECAY_DAYS=30

# Pattern confidence decay rate (0.0-1.0)
CONFIDENCE_DECAY_RATE=0.1
